# Copy to .env and fill in real values. Never commit .env itself.
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:8081", "http://localhost:19006"]

# Database
DATABASE__URL=postgresql+asyncpg://shecare:shecare@localhost:5432/shecare

# Redis
REDIS__URL=redis://localhost:6379/0
REDIS__RATE_LIMIT_URL=redis://localhost:6379/1
REDIS__CELERY_BROKER_URL=redis://localhost:6379/2
REDIS__CELERY_RESULT_BACKEND=redis://localhost:6379/3

# JWT — replace in staging / production
JWT__SECRET_KEY=dev-only-change-me
JWT__REFRESH_SECRET_KEY=dev-only-change-me

# Twilio (optional in dev — auth module uses mock if empty)
TWILIO__ACCOUNT_SID=
TWILIO__AUTH_TOKEN=
TWILIO__VERIFY_SERVICE_SID=
TWILIO__FROM_NUMBER=

# FCM
FCM__SERVICE_ACCOUNT_JSON_PATH=

# Stream Chat
STREAM__API_KEY=
STREAM__API_SECRET=

# S3 / MinIO
S3__ENDPOINT_URL=http://localhost:9000
S3__AWS_ACCESS_KEY_ID=shecare
S3__AWS_SECRET_ACCESS_KEY=shecare123
S3__BUCKET_VIDEOS=shecare-videos
S3__BUCKET_AVATARS=shecare-avatars
S3__REGION=us-east-1

# Hugging Face
HUGGINGFACE__API_TOKEN=

# Encryption — replace in staging / production
ENCRYPTION__MASTER_KEY=dev-only-fernet-key-replace-in-prod
ENCRYPTION__PBKDF2_ITERATIONS=600000

# Safety
SAFETY__ESCALATION_EMAIL=safety-alerts@shecare.example
SAFETY__PAGERDUTY_ROUTING_KEY=
